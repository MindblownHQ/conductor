{
	"name": "shop-maestro/conductor",
	"description": "Basis of every self-respecting Shop Maestro plugin",
	"license": "GPL-2.0-or-later",
	"type": "composer-plugin",
	"authors": [
		{
			"name": "Shop Maestro",
			"email": "info@shop-maestro.com"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"ShopMaestro\\Conductor\\": "src/"
		},
		"files": [
			"src/functions.php"
		]
	},
	"require": {
		"php": ">=7.4",
		"illuminate/collections": "^8.83",
		"illuminate/database": "^8.83",
		"yahnis-elsts/plugin-update-checker": "^5.5",
		"humbug/php-scoper": "^0.18.7",
		"composer-plugin-api": "^2.0"
	},
    "scripts": {
        "prefix-dependencies": [
            "@php vendor/humbug/php-scoper/bin/php-scoper add-prefix --prefix=Shop_Maestro_Vendor --output-dir=./vendor_prefixed/ --config=config/php-scoper/dependency-injection.inc.php --force --quiet"
        ]
    },
    "extra": {
        "class": "ShopMaestro\\Conductor\\PrefixDependenciesPlugin"
    }
}
